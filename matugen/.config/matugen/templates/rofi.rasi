* {
    urgent:      		{{ colors.error.default.hex }};
    info:        		{{ colors.primary_container.default.hex }};
    bright-fg:         		{{ colors.on_background.default.hex }};
    dim-bg:            		{{ colors.secondary_container.default.hex }};
    foreground:        		{{ colors.primary.default.hex }};
    background:        		{{ colors.surface.default.hex }};
}

