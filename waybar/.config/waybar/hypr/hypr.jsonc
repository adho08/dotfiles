// Load modules
{
  "layer": "top",
  "position": "top",
  "height": 54,
  "exclusive": true,
  "style": "~/.config/waybar/hypr/hypr.css",
  "include": ["~/.config/waybar/modules.json"],
  "modules-left": [
    "custom/distro-icon",
    "hyprland/workspaces",
    "mpris#prev",
    "mpris#playpause",
    "mpris#next",
    "mpris",
  ],
  "modules-center": ["clock"],
  "modules-right": [
    "bluetooth",
    "pulseaudio",
    "network",
    "backlight",
    "battery",
    "custom/power",
  ],
}
